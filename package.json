{
	"name": "xamsa",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/node": "^22.13.14",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"tailwindcss": "^4.1.18",
			"@prisma/client": "^7.2.0",
			"@orpc/server": "^1.12.2",
			"@orpc/client": "^1.12.2",
			"@orpc/openapi": "^1.12.2",
			"@orpc/zod": "^1.12.2",
			"better-auth": "1.5.5",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"db:push": "turbo -F @xamsa/db db:push",
		"db:studio": "turbo -F @xamsa/db db:studio",
		"db:generate": "turbo -F @xamsa/db db:generate",
		"db:migrate": "turbo -F @xamsa/db db:migrate",
		"db:seed": "turbo -F @xamsa/db db:seed",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@xamsa/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/node": "catalog:",
		"@xamsa/config": "workspace:*",
		"lefthook": "^2.0.13",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.4"
}
