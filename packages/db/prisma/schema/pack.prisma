enum PackVisibility {
  public // anyone can view the pack (if published)
  private // only the author can view the pack
}

enum PackStatus {
  draft // the author is working on the pack
  published // the author has published the pack
  archived // the author has archived the pack
}

enum PackLanguage {
  en // English
  az // Azerbaijani
  ru // Russian
  tr // Turkish
}

model Pack {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  visibility PackVisibility @default(public)
  status     PackStatus     @default(draft)

  slug        String       @unique
  name        String /// @zod.string().min(3, "Name must be at least 3 characters long").max(100, "Name must be less than 100 characters long")
  description String? /// @zod.string().max(1000, "Description must be less than 1000 characters")
  image       String? /// @zod.string().url("Invalid image URL")
  language    PackLanguage @default(az)

  /// stats ///
  averageRating Float @default(0) @map("average_rating")
  totalRatings  Int   @default(0) @map("total_ratings")
  totalPlays    Int   @default(0) @map("total_plays")

  /// config ///
  allowOthersHost Boolean @default(false) @map("allow_others_host") // other people can also host a game with this pack
  showTopicsInfo  Boolean @default(true) @map("show_topics_info") // will show list of topics in the pack page

  /// difficulty (see DIFFICULTY_RATE_IMPLEMENTATION_SPEC) ///
  pdr           Float     @default(4.5) @map("pdr")
  pdrUpdatedAt  DateTime? @map("pdr_updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])

  ratings PackRating[]
  topics  Topic[]
  games   Game[]

  tsualPackageImports UserTsualPackageImport[]

  @@index([slug])
  @@index([authorId])
  @@index([totalPlays])
  @@index([averageRating])
  @@map("pack")
}

model PackRating {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rating   Int /// @zod.number().min(0, "Rating must be at least 0").max(5, "Rating must be less than or equal to 5")
  feedback String? /// @zod.string().max(1000, "Feedback must be less than 1000 characters")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  packId String @map("pack_id")
  pack   Pack   @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
  @@index([rating])
  @@map("pack_rating")
}

model Topic {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slug        String
  order       Int /// @zod.number().min(1, "Order must be at least 1").max(100, "Order must be less than or equal to 100")
  name        String /// @zod.string().min(2, "Name must be at least 2 characters long").max(100, "Name must be less than 100 characters long")
  description String? /// @zod.string().max(1000, "Description must be less than 1000 characters")

  packId String @map("pack_id")
  pack   Pack   @relation(fields: [packId], references: [id], onDelete: Cascade)

  /// difficulty (see DIFFICULTY_RATE_IMPLEMENTATION_SPEC) ///
  tdr          Float     @default(4.5) @map("tdr")
  tdrUpdatedAt DateTime? @map("tdr_updated_at")

  questions Question[]
  clicks    Click[]
  games     GameTopic[]

  @@unique([packId, order])
  @@unique([packId, slug])
  @@index([packId])
  @@index([slug])
  @@index([order])
  @@map("topic")
}

model Question {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slug              String
  order             Int /// @zod.number().min(1, "Order must be at least 1").max(5, "Order must be less than or equal to 5")
  text              String /// @zod.string().min(2, "Text must be at least 2 characters long").max(1000, "Text must be less than 1000 characters")
  description       String? /// @zod.string().max(1000, "Description must be less than 1000 characters")
  answer            String /// @zod.string().min(1, "Answer must be at least 1 character long").max(250, "Answer must be less than 250 characters")
  acceptableAnswers String[] @map("acceptable_answers") /// @zod.max(5, "Acceptable answers must be less than or equal to 5")
  explanation       String? /// @zod.string().max(1000, "Explanation must be less than 1000 characters")

  topicId       String         @map("topic_id")
  topic         Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  /// difficulty (see DIFFICULTY_RATE_IMPLEMENTATION_SPEC) ///
  qdr               Float     @default(4.5) @map("qdr")
  qdrEloEquiv       Float     @default(1000) @map("qdr_elo_equiv")
  qdrScoredAttempts Int       @default(0) @map("qdr_scored_attempts")
  qdrUpdatedAt      DateTime? @map("qdr_updated_at")
  clicks        Click[]
  gameQuestions GameQuestion[]

  @@unique([topicId, order])
  @@unique([topicId, slug])
  @@index([topicId])
  @@index([slug])
  @@index([order])
  @@map("question")
}
