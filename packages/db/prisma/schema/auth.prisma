enum Role {
  user
  moderator
  admin
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  username String  @unique /// @zod.string().min(3, "Username must be at least 3 characters long").max(30, "Username must be less than 30 characters long").regex(/^[a-z][a-z0-9]+$/, "Username must contain only lowercase letters and numbers and cannot start with a number")
  email    String  @unique /// @zod.email("Invalid email address")
  name     String /// @zod.string().min(3, "Name must be at least 3 characters long").max(100, "Name must be less than 100 characters long")
  image    String? /// @zod.string().url("Invalid image URL")
  role     Role    @default(user)

  emailVerified    Boolean  @default(false) @map("email_verified")
  twoFactorEnabled Boolean? @default(false) @map("two_factor_enabled")

  /// progression ///
  xp    Int @default(0)
  level Int @default(1)

  /// elo ///
  elo       Int @default(1000)
  peakElo   Int @default(1000) @map("peak_elo")
  lowestElo Int @default(1000) @map("lowest_elo")

  /// game counts ///
  totalGamesHosted Int @default(0) @map("total_games_hosted")
  totalGamesPlayed Int @default(0) @map("total_games_played")

  /// performance ///
  totalPointsEarned Int @default(0) @map("total_points_earned")
  totalWins         Int @default(0) @map("total_wins")
  totalPodiums      Int @default(0) @map("total_podiums") // top-3
  totalLastPlaces   Int @default(0) @map("total_last_places")

  /// content counts (cumilative) ///
  totalTopicsPlayed    Int @default(0) @map("total_topics_played")
  totalQuestionsPlayed Int @default(0) @map("total_questions_played")

  /// answers ///
  totalCorrectAnswers   Int @default(0) @map("total_correct_answers")
  totalIncorrectAnswers Int @default(0) @map("total_incorrect_answers")
  totalExpiredAnswers   Int @default(0) @map("total_expired_answers")
  totalFirstClicks      Int @default(0) @map("total_first_clicks")

  /// time spent (seconds) ///
  totalTimeSpentPlaying Int @default(0) @map("total_time_spent_playing")
  totalTimeSpentHosting Int @default(0) @map("total_time_spent_hosting")

  /// content creation ///
  totalPacksPublished Int @default(0) @map("total_packs_published")

  /// AI topic generation (daily quota, UTC day window) ///
  lastAiUsedAt     DateTime? @map("last_ai_used_at")
  aiUseCount       Int       @default(0) @map("ai_use_count")
  /// Start of the UTC day for which `aiUseCount` applies (midnight UTC)
  aiUseWindowDate  DateTime? @map("ai_use_window_date")

  sessions   Session[]
  accounts   Account[]
  twofactors TwoFactor[]
  packs      Pack[]
  ratings    PackRating[]
  hosted     Game[]
  players    Player[]

  @@index([elo])
  @@index([xp])
  @@index([totalWins])
  @@index([totalPointsEarned])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  expiresAt DateTime @map("expires_at")

  token     String  @unique
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")

  accountId    String  @map("account_id")
  providerId   String  @map("provider_id")
  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  idToken      String? @map("id_token")
  scope        String? @map("scope")
  /// @zod.string().min(7, "Password must be at least 7 characters long").max(100, "Password must be less than 100 characters long").regex(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{7,}$/, "Password must contain at least one uppercase letter, one lowercase letter, and one digit")
  password     String? @map("password")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  expiresAt DateTime @map("expires_at")

  identifier String
  value      String

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  secret      String
  backupCodes String @map("backup_codes")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
