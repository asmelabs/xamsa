/// One row per user per 3sual package they successfully imported (topic.bulkCreate with import id).
model UserTsualPackageImport {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId         String @map("user_id")
  /// 3sual API package id (integer from api.3sual.az)
  tsualPackageId Int    @map("tsual_package_id")
  /// Pack the topics were created into
  packId         String @map("pack_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([userId, tsualPackageId])
  @@index([tsualPackageId])
  @@index([packId])
  @@map("user_tsual_package_import")
}
